# API Gateway URL (where LibreChat proxies chat requests)
API_GATEWAY_URL=http://api-gateway:8000

# API key used as a required placeholder for LibreChat's custom endpoint config.
# The real per-user Authorization header is injected by the platform layer
# (AuthBridge + patchFetch) using the Entra JWT, so this key is never
# validated by the API Gateway in production.
AGENT_API_KEY=dev-key-placeholder

# LibreChat application secret
LIBRECHAT_SECRET_KEY=your-secret-here-change-in-production

# LibreChat upstream crypto vars (required by api/server/utils/crypto.js)
# CREDS_KEY: 64 hex chars (32 bytes); CREDS_IV: 32 hex chars (16 bytes)
CREDS_KEY=your-64-char-hex-key-here
CREDS_IV=your-32-char-hex-iv-here
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# MongoDB (used by LibreChat for conversation history)
MONGO_URI=mongodb://mongo:27017/LibreChat

# App title (shown in browser tab + header)
APP_TITLE=Video Extract Platform

# ─── SSO / Token Bridge ─────────────────────────────────────────────────────
#
# ALLOW_REGISTRATION must remain "true" so the Angular shell can
# programmatically create a LibreChat user on behalf of each Entra user
# (POST /api/auth/register + POST /api/auth/login).
#
# Users never see LibreChat's registration or login UI because:
#   1. Angular calls /api/auth/login with credentials: 'include' — the browser
#      stores the HttpOnly refreshToken cookie for localhost:3080.  When the
#      iframe loads, /api/auth/refresh runs silently and restores the session.
#   2. registration.socialLogins: [] in librechat.yaml hides auth UI links.
#
# ANGULAR_ORIGIN: the origin of the Angular shell as seen by the user's
# browser.  Required so LibreChat's CORS allows credentials: 'include' from
# the Angular app.  Must be a specific origin — not a wildcard.
# Local dev: http://localhost:4200
# Production: https://<your-front-door-domain>
ANGULAR_ORIGIN=http://localhost:4200
#
# In local dev (LOCAL_DEV_SKIP_AUTH=true on the API Gateway) the Angular
# shell provisions a fixed dev@local account automatically.
ALLOW_REGISTRATION=true
ALLOW_UNVERIFIED_EMAIL=true
