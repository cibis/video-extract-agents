# Azure Entra External ID credentials — required for local sign-in testing.
# Leave unset to run without auth (LOCAL_DEV_SKIP_AUTH=true on api-gateway).
AZURE_ENTRA_CLIENT_ID=your-client-id
AZURE_ENTRA_TENANT_ID=your-tenant-id

# Base URL used as the OAuth2 redirect URI.
# Defaults to http://localhost:4200 in docker-compose when not set.
APP_BASE_URL=http://localhost:4200
