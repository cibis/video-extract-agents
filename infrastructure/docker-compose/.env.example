# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgresql:5432/videoextract

# ── Azure Storage (Azurite local emulator) ────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=videos

# ── Azure Service Bus (emulator) ───────────────────────────────────────────────
# Replace key with actual emulator key from servicebus-emulator config
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://servicebus-emulator;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;

# ── LLM model ─────────────────────────────────────────────────────────────────
# Agent reasoning model (LiteLLM model string):
#   anthropic/claude-sonnet-4-6  |  openai/gpt-4o  |  bedrock/us.anthropic.claude-sonnet-4-5-20251001-v1:0
#AGENT_MODEL=anthropic/claude-sonnet-4-6
AGENT_MODEL=bedrock/us.amazon.nova-2-lite-v1:0

# Vision/frontier model for mcp-server-analysis:
#   anthropic/claude-opus-4-6  |  openai/gpt-4o  |  bedrock/us.anthropic.claude-opus-4-5-v1:0
#TOOL_FRONTIER_MODEL=anthropic/claude-opus-4-6
TOOL_FRONTIER_MODEL=bedrock/us.amazon.nova-2-lite-v1:0

# Optional alias overrides for mcp-server-analysis (comma-separated alias=model pairs):
# MODEL_ALIASES_OVERRIDE=claude-vision=openai/gpt-4o,claude-haiku=openai/gpt-4o-mini
MODEL_ALIASES_OVERRIDE=

# ── Provider credentials — set whichever matches your chosen models ────────────
# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OpenAI
OPENAI_API_KEY=
# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# ── Azure Communication Services (not used locally — NOTIFICATION_MODE=stdout) ─
AZURE_COMMUNICATION_SERVICES_CONNECTION_STRING=

# ── Azure Entra External ID (not used locally — LOCAL_DEV_SKIP_AUTH=true) ──────
AZURE_ENTRA_TENANT_ID=
AZURE_ENTRA_CLIENT_ID=
AZURE_ENTRA_JWKS_URI=

# ── Azure Front Door (not used locally — OUTPUT_URL_MODE=local) ────────────────
FRONT_DOOR_ENDPOINT=
FRONT_DOOR_SECRET=

# ── MCP Server URLs ────────────────────────────────────────────────────────────
MCP_ANALYSIS_URL=http://mcp-server-analysis:8100
MCP_PROCESSING_URL=http://mcp-server-processing:8200

# ── Application Insights (empty = disabled locally) ───────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── LibreChat ─────────────────────────────────────────────────────────────────
LIBRECHAT_SECRET_KEY=local-dev-secret-change-in-production
AGENT_API_KEY=dev-key-local
