AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=videos
APPLICATIONINSIGHTS_CONNECTION_STRING=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgresql:5432/videoextract

# ── Frontier vision model (LiteLLM model string) ──────────────────────────────
# Anthropic direct:  anthropic/claude-opus-4-6
# OpenAI:            openai/gpt-4o
# AWS Bedrock:       bedrock/us.anthropic.claude-opus-4-5-v1:0
TOOL_FRONTIER_MODEL=bedrock/us.amazon.nova-2-lite-v1:0

# Optional alias overrides (comma-separated alias=model pairs), e.g.:
# MODEL_ALIASES_OVERRIDE=claude-vision=openai/gpt-4o,claude-haiku=openai/gpt-4o-mini
MODEL_ALIASES_OVERRIDE=

# ── Tool RPM limit ─────────────────────────────────────────────────────────────
# Maximum frontier model requests per minute for tool calls.
# Leave empty for no limit.  Default: 4 (= 1 call per 15 s).
# Can also be set at runtime in the app_settings DB table (key: tool_rpm_limit).
TOOL_RPM_LIMIT=4

# ── Output token budget ────────────────────────────────────────────────────────
# Tokens reserved per frame for structured JSON output.
# Actual max_tokens sent to the model = min(n_frames × FRONTIER_TOKENS_PER_FRAME, FRONTIER_MAX_TOKENS).
FRONTIER_TOKENS_PER_FRAME=150

# Hard ceiling on output tokens per vision call.  Must not exceed the model's
# own max output token limit:
#   bedrock/us.amazon.nova-2-lite-v1:0  →  5120  (default — safe for up to ~27 frames)
#   anthropic/claude-haiku-4-5-*        →  8192
#   anthropic/claude-opus-4-6           → 32000
FRONTIER_MAX_TOKENS=4096

# ── Provider credentials — set whichever matches TOOL_FRONTIER_MODEL ─────────
# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OpenAI
OPENAI_API_KEY=
# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1
