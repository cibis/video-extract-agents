# Node environment
NODE_ENV=development
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@postgresql:5432/videoextract

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=videos

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://servicebus-emulator:5672;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key-here;

# Azure Entra External ID (JWT validation)
AZURE_ENTRA_TENANT_ID=your-tenant-id
AZURE_ENTRA_CLIENT_ID=your-client-id
AZURE_ENTRA_JWKS_URI=https://login.microsoftonline.com/your-tenant-id/discovery/v2.0/keys

# Azure Front Door (for signed output URLs)
FRONT_DOOR_ENDPOINT=https://your-frontdoor.azurefd.net
FRONT_DOOR_SECRET=your-frontdoor-secret

# Agent Orchestrator (internal)
AGENT_ORCHESTRATOR_URL=http://agent-orchestrator:8001

# Local dev flags (set to true locally, NEVER in CI/Azure)
LOCAL_DEV_SKIP_AUTH=false

# Output URL mode: local | frontdoor
OUTPUT_URL_MODE=frontdoor

# Base URL used to construct blob-proxy upload URLs in local dev mode.
# Set to http://localhost:8000 for browser access (default).
# Set to http://api-gateway:8000 when the caller is inside the Docker network (e2e test-runner).
BLOB_PROXY_BASE_URL=http://localhost:8000

# Application Insights (empty = disabled)
APPLICATIONINSIGHTS_CONNECTION_STRING=
