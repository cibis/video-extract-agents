# ── LLM model (LiteLLM model string) ──────────────────────────────────────────
# Anthropic direct:  anthropic/claude-sonnet-4-6
# OpenAI:            openai/gpt-4o
# AWS Bedrock:       bedrock/us.anthropic.claude-sonnet-4-5-20251001-v1:0
AGENT_MODEL=anthropic/claude-sonnet-4-6

# ── Agent RPM limit ────────────────────────────────────────────────────────────
# Maximum LLM requests per minute for agent calls.
# Leave empty for no limit.  Default: 4 (= 1 call per 15 s).
# Can also be set at runtime in the app_settings DB table (key: agent_rpm_limit).
AGENT_RPM_LIMIT=4

# ── Provider credentials — set whichever matches AGENT_MODEL ──────────────────
# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OpenAI
OPENAI_API_KEY=
# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgresql:5432/videoextract

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://servicebus-emulator:5672;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key-here;

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=videos

# MCP Server URLs
MCP_ANALYSIS_URL=http://mcp-server-analysis:8100
MCP_PROCESSING_URL=http://mcp-server-processing:8200

# Application Insights (empty = disabled locally)
APPLICATIONINSIGHTS_CONNECTION_STRING=
