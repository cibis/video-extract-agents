#!/usr/bin/env bash
# scripts/credentials.sh.example  (committed — no real secrets)
#
# Copy this file to scripts/credentials.sh, fill in your values, and
# never commit the filled-in copy (it is gitignored).
#
# Sourced by bootstrap-dev.sh, bootstrap-prod.sh, and teardown.sh.
#
# Usage (in other scripts):
#   source "$(dirname "${BASH_SOURCE[0]}")/credentials.sh"

# ─── Azure service principal credentials ──────────────────────────────────────
# Create with: az ad sp create-for-rbac --name "video-extract-ci" --role Contributor
#              --scopes /subscriptions/<SUBSCRIPTION_ID> --output json
# GitLab CI/CD variables: AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID, AZURE_SUBSCRIPTION_ID

export ARM_CLIENT_ID="<service-principal-app-id>"            # AZURE_CLIENT_ID
export ARM_CLIENT_SECRET="<service-principal-secret>"        # AZURE_CLIENT_SECRET
export ARM_TENANT_ID="<azure-ad-tenant-id>"                  # AZURE_TENANT_ID
export ARM_SUBSCRIPTION_ID="<azure-subscription-id>"         # AZURE_SUBSCRIPTION_ID

# Used by teardown.sh (AZURE_* → ARM_* mapping) and as TF_VAR_* source
export AZURE_CLIENT_ID="$ARM_CLIENT_ID"
export AZURE_CLIENT_SECRET="$ARM_CLIENT_SECRET"
export AZURE_TENANT_ID="$ARM_TENANT_ID"
export AZURE_SUBSCRIPTION_ID="$ARM_SUBSCRIPTION_ID"

# ─── Terraform state backend ──────────────────────────────────────────────────
# Retrieve: az storage account keys list --account-name tfstatevideoextract
#             --resource-group terraform-state-rg --query "[0].value" -o tsv
# GitLab CI/CD variable: TF_STATE_ACCESS_KEY

export TF_STATE_ACCESS_KEY="<storage-account-access-key>"   # TF_STATE_ACCESS_KEY in GitLab

# ─── Required Terraform input variables ───────────────────────────────────────

export TF_VAR_subscription_id="$ARM_SUBSCRIPTION_ID"
export TF_VAR_db_admin_password="<strong-postgres-password>"  # DB_ADMIN_PASSWORD in GitLab
export DB_ADMIN_PASSWORD="$TF_VAR_db_admin_password"          # used by teardown.sh

# ─── Optional — API keys ──────────────────────────────────────────────────────

export TF_VAR_anthropic_api_key="sk-ant-api03-..."           # ANTHROPIC_API_KEY in GitLab
export TF_VAR_openai_api_key=""
export TF_VAR_aws_access_key_id=""
export TF_VAR_aws_secret_access_key=""
export TF_VAR_aws_region_name="us-east-1"

# ─── Optional — Entra External ID ─────────────────────────────────────────────
# See getting-started.md §6 for how to obtain these values

export TF_VAR_entra_tenant_id="<entra-external-id-tenant-id>"
export TF_VAR_entra_client_id="<entra-api-app-registration-client-id>"
